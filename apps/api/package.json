    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/node": "^22.13.0",
    "eslint": "^9.21.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript-eslint": "^8.26.1",
    "typescript": "^5.8.3"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
