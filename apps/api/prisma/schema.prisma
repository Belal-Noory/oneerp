  @@index([tenantId, pumpId])
  @@index([tenantId, tankId])
}

model FuelShift {
  id              String          @id @default(uuid())
  tenantId        String
  status          FuelShiftStatus @default(open)
  openedAt        DateTime        @default(now())
  closedAt        DateTime?
  openedByUserId  String?
  closedByUserId  String?
  expectedRevenue Decimal         @default(0) @db.Decimal(14, 2)
  actualRevenue   Decimal         @default(0) @db.Decimal(14, 2)
  difference      Decimal         @default(0) @db.Decimal(14, 2)
  note            String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant   Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  openedBy User?                    @relation("FuelShiftOpenedBy", fields: [openedByUserId], references: [id], onDelete: SetNull)
  closedBy User?                    @relation("FuelShiftClosedBy", fields: [closedByUserId], references: [id], onDelete: SetNull)
