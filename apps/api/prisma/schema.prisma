}

model ShopInvoiceLotAllocation {
  id            String   @id @default(uuid())
  tenantId      String
  invoiceId     String
  invoiceLineId String
  lotId         String
  quantity      Decimal  @db.Decimal(14, 3)
  createdAt     DateTime @default(now())

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice ShopInvoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  line    ShopInvoiceLine @relation(fields: [invoiceLineId], references: [id], onDelete: Cascade)
  lot     ShopStockLot    @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([tenantId, invoiceId])
  @@index([tenantId, invoiceLineId])
  @@index([tenantId, lotId])
}

model ShopInvoicePayment {
  id            String               @id @default(uuid())
  tenantId      String
  invoiceId     String
  cashSessionId String?
  direction     ShopPaymentDirection @default(in)
  method        String
  amount        Decimal              @db.Decimal(14, 2)
  note          String?
  actorUserId   String?
  createdAt     DateTime             @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice     ShopInvoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  cashSession ShopCashSession? @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)
  actor       User?            @relation("ShopInvoicePaymentActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, invoiceId, createdAt(sort: Desc)])
  @@index([tenantId, cashSessionId, createdAt(sort: Desc)])
}

model ReferralCode {
  id        String   @id @default(uuid())
  code      String   @unique
  tenantId  String?
  userId    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  referrals Referral[] @relation("ReferralReferrerCode")

  @@unique([tenantId])
  @@unique([userId])
  @@index([tenantId])
  @@index([userId])
}

model Referral {
  id                String         @id @default(uuid())
  referrerCodeId    String
  referrerTenantId  String?
  referrerUserId    String?
  referredTenantId  String
  referredUserId    String
  source            String?
  moduleId          String?
  status            ReferralStatus @default(pending)
  registeredAt      DateTime       @default(now())
  moduleRequestedAt DateTime?
  paymentReceivedAt DateTime?
  activatedAt       DateTime?
  rewardGrantedAt   DateTime?
  rejectedAt        DateTime?
  rejectedReason    String?

  referrerCode   ReferralCode @relation("ReferralReferrerCode", fields: [referrerCodeId], references: [id], onDelete: Restrict)
  referrerTenant Tenant?      @relation("ReferralsAsReferrerTenant", fields: [referrerTenantId], references: [id], onDelete: SetNull)
  referrerUser   User?        @relation("ReferralsAsReferrerUser", fields: [referrerUserId], references: [id], onDelete: SetNull)
  referredTenant Tenant       @relation("ReferralsAsReferredTenant", fields: [referredTenantId], references: [id], onDelete: Cascade)
  referredUser   User         @relation("ReferralsAsReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([referredTenantId])
  @@index([referrerTenantId, status, registeredAt(sort: Desc)])
  @@index([referrerUserId, status, registeredAt(sort: Desc)])
  @@index([referredTenantId, status])
}

model ReferralRewardGrant {
  id              String             @id @default(uuid())
  tenantId        String
  rewardType      ReferralRewardType
  grantedAt       DateTime           @default(now())
  grantedByUserId String?
  metadataJson    Json

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  grantedBy User?  @relation("ReferralRewardGrantedBy", fields: [grantedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, rewardType])
  @@index([tenantId, grantedAt(sort: Desc)])
}

model TenantPartnerProfile {
  tenantId               String    @id
  isPremiumPartner       Boolean   @default(false)
  premiumGrantedAt       DateTime?
  premiumGrantedByUserId String?
  betaAccessEnabled      Boolean   @default(false)
  betaEnabledAt          DateTime?
  betaEnabledByUserId    String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  tenant           Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  premiumGrantedBy User?  @relation("TenantPartnerPremiumGrantedBy", fields: [premiumGrantedByUserId], references: [id], onDelete: SetNull)
  betaEnabledBy    User?  @relation("TenantPartnerBetaEnabledBy", fields: [betaEnabledByUserId], references: [id], onDelete: SetNull)

  @@index([isPremiumPartner])
}

model PartnerFeedback {
  id             String   @id @default(uuid())
  tenantId       String
  userId         String
  subject        String
  message        String
  isBetaFeedback Boolean  @default(false)
  status         String   @default("open")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
}

model ActivationRequestTracking {
  id                 String                  @id @default(uuid())
  tenantId           String
  moduleId           String
  subscriptionItemId String?
  status             ActivationRequestStatus @default(pending)
  requestedAt        DateTime                @default(now())
  paymentReceivedAt  DateTime?
  activatedAt        DateTime?
  rejectedAt         DateTime?
  paymentNotes       String?
  activationNotes    String?
  confirmedByUserId  String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptionItem SubscriptionItem? @relation(fields: [subscriptionItemId], references: [id], onDelete: SetNull)
  confirmedBy      User?             @relation("ActivationRequestConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, moduleId])
  @@unique([subscriptionItemId])
  @@index([status, requestedAt(sort: Desc)])
}

model PlatformReferralSettings {
  id                        String   @id @default("default")
  bundleStepPercent         Int      @default(5)
  bundleMaxPercent          Int      @default(25)
  loyaltyExtraPercent       Int      @default(5)
  invoiceDiscountPercent    Int      @default(10)
  freeMonthAtReferrals      Int      @default(3)
  premiumPartnerAtReferrals Int      @default(5)
  loyaltyExtraAtReferrals   Int      @default(10)
  updatedAt                 DateTime @updatedAt
}
