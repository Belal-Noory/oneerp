  id            String         @id @default(uuid())
  tenantId      String
  shiftId       String?
  nozzleId      String
  customerId    String?
  driverName    String?
  licensePlate  String?
  volume        Decimal        @db.Decimal(14, 2)
  pricePerUnit  Decimal        @db.Decimal(14, 2)
  totalAmount   Decimal        @db.Decimal(14, 2)
  paymentMethod String // cash, credit, card, etc.
  status        FuelSaleStatus @default(posted)
  invoiceNumber String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shift    FuelShift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  nozzle   FuelNozzle    @relation(fields: [nozzleId], references: [id], onDelete: Restrict)
  customer ShopCustomer? @relation("FuelSaleCustomer", fields: [customerId], references: [id], onDelete: SetNull)

  @@index([tenantId, shiftId])
  @@index([tenantId, nozzleId])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
}

model FuelReceiving {
