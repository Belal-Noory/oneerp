  pricePerUnit   Decimal  @db.Decimal(14, 2)
  totalAmount    Decimal  @default(0) @db.Decimal(14, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shift  FuelShift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  nozzle FuelNozzle @relation(fields: [nozzleId], references: [id], onDelete: Cascade)

  @@index([tenantId, shiftId])
  @@index([tenantId, nozzleId])
}

