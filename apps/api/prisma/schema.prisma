  sales    FuelSale[]

  @@index([tenantId, status])
  @@index([tenantId, openedAt(sort: Desc)])
}

model FuelShiftNozzleReading {
  id             String   @id @default(uuid())
  tenantId       String
  shiftId        String
  nozzleId       String
  openingReading Decimal  @db.Decimal(14, 2)
  closingReading Decimal? @db.Decimal(14, 2)
