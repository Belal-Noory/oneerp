generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum TenantStatus {
  active
  disabled
}

enum MembershipStatus {
  active
  invited
  suspended
}

enum EnabledModuleStatus {
  enabled
  disabled
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  suspended
  canceled
}

enum ShopStockMovementType {
  receive
  adjust
  transfer_out
  transfer_in
  sale
  sale_void
  sale_refund
  sale_refund_void
  supplier_return
}

enum ShopInvoiceStatus {
  draft
  posted
  void
}

enum ShopInvoiceKind {
  sale
  refund
}

enum ShopPaymentDirection {
  in
  out
}

enum ShopPaymentMethodKind {
  cash
  card
  bank
  mobile
  other
}

enum ShopCashSessionStatus {
  open
  closed
}

enum ShopCashSessionEventType {
  cash_in
  cash_out
}

enum ReferralStatus {
  pending
  awaiting_payment_confirmation
  payment_received
  activated
  reward_granted
  rejected
}

enum ReferralRewardType {
  invoice_discount_10
  free_month
  premium_partner
  loyalty_extra_5
}

enum ActivationRequestStatus {
  pending
  payment_received
  activated
  rejected
}

enum SupportTicketType {
  issue_report
  support_request
  feature_suggestion
  billing
  other
}

enum SupportTicketStatus {
  open
  in_progress
  waiting_for_client
  resolved
  closed
  under_review
  planned
  in_development
  completed
  rejected
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent
}

enum SupportSenderType {
  tenant
  owner
}

enum SupportNotificationType {
  new_ticket
  new_message
  status_changed
}

model User {
  id           String   @id @default(uuid())
  email        String?  @unique
  phone        String?  @unique
  fullName     String
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships                 Membership[]
  authSessions                AuthSession[]
  passwordResetTokens         PasswordResetToken[]
  auditLogs                   AuditLog[]
  shopStockMovements          ShopStockMovement[]          @relation("ShopStockMovementActor")
  shopInvoicePayments         ShopInvoicePayment[]         @relation("ShopInvoicePaymentActor")
  shopCashSessionsOpened      ShopCashSession[]            @relation("ShopCashSessionOpenedBy")
  shopCashSessionsClosed      ShopCashSession[]            @relation("ShopCashSessionClosedBy")
  shopCashSessionEvents       ShopCashSessionEvent[]       @relation("ShopCashSessionEventActor")
  shopPurchaseInvoicePayments ShopPurchaseInvoicePayment[] @relation("ShopPurchaseInvoicePaymentActor")
  shopPurchaseOrdersApproved  ShopPurchaseOrder[]          @relation("ShopPurchaseOrderApprovedBy")
  shopPurchaseOrdersClosed    ShopPurchaseOrder[]          @relation("ShopPurchaseOrderClosedBy")
  shopPurchaseLotReceipts     ShopPurchaseLotReceipt[]     @relation("ShopPurchaseLotReceiptActor")
  approvedSubscriptionItems   SubscriptionItem[]           @relation("SubscriptionItemApprovedBy")

  fuelShiftsOpened     FuelShift[]   @relation("FuelShiftOpenedBy")
  fuelShiftsClosed     FuelShift[]   @relation("FuelShiftClosedBy")
  fuelTankDipsRecorded FuelTankDip[] @relation("FuelTankDipRecordedBy")
  fuelPriceUpdates     FuelPrice[]   @relation("FuelPriceUpdatedBy")

  referralCodes                 ReferralCode[]
  referralsAsReferrerUser       Referral[]                  @relation("ReferralsAsReferrerUser")
  referralsAsReferredUser       Referral[]                  @relation("ReferralsAsReferredUser")
  referralRewardsGrantedBy      ReferralRewardGrant[]       @relation("ReferralRewardGrantedBy")
  partnerPremiumGrantedTenants  TenantPartnerProfile[]      @relation("TenantPartnerPremiumGrantedBy")
  partnerBetaEnabledTenants     TenantPartnerProfile[]      @relation("TenantPartnerBetaEnabledBy")
  activationRequestsConfirmedBy ActivationRequestTracking[] @relation("ActivationRequestConfirmedBy")
  partnerFeedbacks              PartnerFeedback[]

  supportTicketsCreated       SupportTicket[]       @relation("SupportTicketCreatedBy")
  supportTicketsAssigned      SupportTicket[]       @relation("SupportTicketAssignedTo")
  supportMessages             SupportMessage[]      @relation("SupportMessageSender")
  supportAttachmentsUploaded  SupportAttachment[]   @relation("SupportAttachmentUploader")
  supportNotificationsReceived SupportNotification[] @relation("SupportNotificationRecipientUser")
}

model Tenant {
  id            String       @id @default(uuid())
  slug          String       @unique
  legalName     String
  displayName   String
  status        TenantStatus @default(active)
  defaultLocale String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  branding                    TenantBranding?
  settings                    TenantSettings?
  memberships                 Membership[]
  membershipEnabledModules    MembershipEnabledModule[]
  roles                       Role[]
  rolePermissions             RolePermission[]
  enabledModules              TenantEnabledModule[]
  subscription                Subscription?
  subscriptionItems           SubscriptionItem[]
  files                       File[]
  auditLogs                   AuditLog[]
  passwordResetTokens         PasswordResetToken[]
  authSessions                AuthSession[]
  shopCategories              ShopCategory[]
  shopProducts                ShopProduct[]
  shopProductBarcodes         ShopProductBarcode[]
  shopProductPackagings       ShopProductPackaging[]
  shopProductPharmacyProfiles ShopProductPharmacyProfile[]
  shopSettings                ShopSettings?
  shopUnits                   ShopUnit[]
  shopLocations               ShopLocation[]
  shopStockItems              ShopStockItem[]
  shopStockLots               ShopStockLot[]
  shopStockMovements          ShopStockMovement[]
  shopCustomers               ShopCustomer[]
  shopInvoices                ShopInvoice[]
  shopInvoiceLines            ShopInvoiceLine[]
  shopInvoiceLotAllocations   ShopInvoiceLotAllocation[]
  shopInvoicePayments         ShopInvoicePayment[]
  shopPaymentMethods          ShopPaymentMethod[]
  shopCashSessions            ShopCashSession[]
  shopCashSessionEvents       ShopCashSessionEvent[]
  shopSuppliers               ShopSupplier[]
  shopPurchaseInvoices        ShopPurchaseInvoice[]
  shopPurchaseInvoicePayments ShopPurchaseInvoicePayment[]
  shopPurchaseInvoiceLines    ShopPurchaseInvoiceLine[]
  shopPurchaseLotReceipts     ShopPurchaseLotReceipt[]
  shopPurchaseOrders          ShopPurchaseOrder[]
  shopPurchaseOrderLines      ShopPurchaseOrderLine[]

  fuelTanks               FuelTank[]
  fuelPumps               FuelPump[]
  fuelNozzles             FuelNozzle[]
  fuelShifts              FuelShift[]
  fuelShiftNozzleReadings FuelShiftNozzleReading[]
  fuelSales               FuelSale[]
  fuelReceivings          FuelReceiving[]
  fuelTankDips            FuelTankDip[]
  fuelPrices              FuelPrice[]

  printPressCustomers           PrintPressCustomer[]
  printPressJobs                PrintPressJob[]
  printPressQuotations          PrintPressQuotation[]
  printPressQuotationLines      PrintPressQuotationLine[]
  printPressInvoices            PrintPressInvoice[]
  printPressInvoiceLines        PrintPressInvoiceLine[]
  printPressInvoicePayments     PrintPressInvoicePayment[]
  printPressExpenses            PrintPressExpense[]
  printPressIncome              PrintPressIncome[]
  printPressSettings            PrintPressSettings?
  printPressCustomerAttachments PrintPressCustomerAttachment[]
  printPressExpenseAttachments  PrintPressExpenseAttachment[]
  printPressRecurringExpenses   PrintPressRecurringExpense[]
  printPressSuppliers           PrintPressSupplier[]

  referralCodes             ReferralCode[]
  referralsAsReferrerTenant Referral[]                  @relation("ReferralsAsReferrerTenant")
  referralsAsReferredTenant Referral[]                  @relation("ReferralsAsReferredTenant")
  referralRewardGrants      ReferralRewardGrant[]
  partnerProfile            TenantPartnerProfile?
  partnerFeedback           PartnerFeedback[]
  activationRequests        ActivationRequestTracking[]

  supportTickets       SupportTicket[]
  supportNotifications SupportNotification[]
}

model SupportTicket {
  id              String               @id @default(uuid())
  tenantId        String
  createdByUserId String
  type            SupportTicketType
  subject         String
  description     String
  status          SupportTicketStatus  @default(open)
  priority        SupportTicketPriority @default(normal)
  assignedToUserId String?
  lastMessageAt   DateTime?
  lastMessageText String?
  lastSenderType  SupportSenderType?
  unreadForTenant Int                  @default(0)
  unreadForOwner  Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User   @relation("SupportTicketCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  assignedTo User?  @relation("SupportTicketAssignedTo", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  messages       SupportMessage[]
  attachments    SupportAttachment[]
  notifications  SupportNotification[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, status, updatedAt(sort: Desc)])
  @@index([status, priority, updatedAt(sort: Desc)])
  @@index([assignedToUserId, updatedAt(sort: Desc)])
}

model SupportMessage {
  id             String          @id @default(uuid())
  ticketId       String
  senderType     SupportSenderType
  senderUserId   String
  message        String
  seenByTenantAt DateTime?
  seenByOwnerAt  DateTime?
  createdAt      DateTime        @default(now())

  ticket  SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender  User          @relation("SupportMessageSender", fields: [senderUserId], references: [id], onDelete: Restrict)
  attachments SupportAttachment[]

  @@index([ticketId, createdAt(sort: Asc)])
  @@index([senderUserId, createdAt(sort: Desc)])
}

model SupportAttachment {
  id           String          @id @default(uuid())
  ticketId     String
  messageId    String?
  uploaderType SupportSenderType
  uploaderUserId String
  originalName String
  contentType  String
  sizeBytes    Int
  storageKey   String
  createdAt    DateTime        @default(now())

  ticket   SupportTicket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message  SupportMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  uploader User           @relation("SupportAttachmentUploader", fields: [uploaderUserId], references: [id], onDelete: Restrict)

  @@index([ticketId, createdAt(sort: Desc)])
  @@index([messageId])
}

model SupportNotification {
  id              String                @id @default(uuid())
  ticketId        String
  tenantId        String
  recipientType   SupportSenderType
  recipientUserId String?
  type            SupportNotificationType
  isRead          Boolean               @default(false)
  createdAt       DateTime              @default(now())
  readAt          DateTime?

  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipientUser User?         @relation("SupportNotificationRecipientUser", fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, recipientUserId, isRead, createdAt(sort: Desc)])
  @@index([ticketId, createdAt(sort: Desc)])
}

model FuelPrice {
  id              String   @id @default(uuid())
  tenantId        String
  fuelType        String
  pricePerUnit    Decimal  @db.Decimal(14, 2)
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  updatedBy User?  @relation("FuelPriceUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, fuelType])
  @@index([tenantId])
}

model TenantBranding {
  id         String   @id @default(uuid())
  tenantId   String   @unique
  logoFileId String?  @unique
  address    String?
  phone      String?
  email      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logo   File?  @relation("TenantLogoFile", fields: [logoFileId], references: [id], onDelete: SetNull)
}

model TenantSettings {
  id               String   @id @default(uuid())
  tenantId         String   @unique
  timezone         String   @default("UTC")
  baseCurrencyCode String   @default("USD")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model ShopSettings {
  id                                 String   @id @default(uuid())
  tenantId                           String   @unique
  sellCurrencyCode                   String   @default("USD")
  buyCurrencyCode                    String   @default("USD")
  taxEnabled                         Boolean  @default(false)
  taxRate                            Decimal  @default(0) @db.Decimal(5, 2)
  cashRoundingIncrement              Decimal  @default(0) @db.Decimal(14, 2)
  pharmacyReceivingRequireLotNumber  Boolean  @default(true)
  pharmacyReceivingRequireExpiryDate Boolean  @default(true)
  nextInvoiceNumber                  Int      @default(1)
  nextRefundNumber                   Int      @default(1)
  nextPurchaseNumber                 Int      @default(1)
  nextPurchaseRefundNumber           Int      @default(1)
  nextPurchaseOrderNumber            Int      @default(1)
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Membership {
  id        String           @id @default(uuid())
  tenantId  String
  userId    String
  roleId    String
  status    MembershipStatus @default(active)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant         Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role                      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  enabledModules MembershipEnabledModule[]

  @@unique([tenantId, userId])
  @@index([tenantId, roleId])
}

model Role {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships     Membership[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model PermissionCatalog {
  key            String   @id
  labelKey       String
  descriptionKey String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  rolePermissions RolePermission[]
}

model RolePermission {
  id            String   @id @default(uuid())
  tenantId      String
  roleId        String
  permissionKey String
  createdAt     DateTime @default(now())

  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role       Role              @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission PermissionCatalog @relation(fields: [permissionKey], references: [key], onDelete: Cascade)

  @@unique([tenantId, roleId, permissionKey])
  @@index([tenantId, roleId])
}

model ModuleCatalog {
  id             String   @id
  version        String
  nameKey        String
  descriptionKey String
  category       String
  icon           String
  manifestJson   Json
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  enabledModules           TenantEnabledModule[]
  membershipEnabledModules MembershipEnabledModule[]
  subscriptionItems        SubscriptionItem[]
  tutorials                Tutorial[]
  tutorialCategories       TutorialCategory[]
  tutorialSeries           TutorialSeries[]
}

model TenantEnabledModule {
  id         String              @id @default(uuid())
  tenantId   String
  moduleId   String
  status     EnabledModuleStatus @default(enabled)
  enabledAt  DateTime?           @default(now())
  disabledAt DateTime?

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module ModuleCatalog @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@index([tenantId, status])
}

model MembershipEnabledModule {
  id           String   @id @default(uuid())
  tenantId     String
  membershipId String
  moduleId     String
  createdAt    DateTime @default(now())

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  membership Membership    @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  module     ModuleCatalog @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, membershipId, moduleId])
  @@index([tenantId, membershipId])
  @@index([tenantId, moduleId])
}

model PlanCatalog {
  code           String   @id
  nameKey        String
  descriptionKey String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique
  planCode             String
  status               SubscriptionStatus @default(trialing)
  trialEndsAt          DateTime?
  currentPeriodStartAt DateTime?
  currentPeriodEndAt   DateTime?
  graceEndsAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  tenant Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   PlanCatalog        @relation(fields: [planCode], references: [code], onDelete: Restrict)
  items  SubscriptionItem[]
}

model SubscriptionItem {
  id                   String    @id @default(uuid())
  tenantId             String
  subscriptionId       String
  moduleId             String
  status               String
  startedAt            DateTime  @default(now())
  endedAt              DateTime?
  subscriptionType     String?
  billingCycle         String?
  listPriceAmount      Decimal?  @db.Decimal(14, 2)
  priceAmount          Decimal?  @db.Decimal(14, 2)
  priceCurrency        String?   @default("USD")
  discountPercent      Int?
  currentPeriodStartAt DateTime?
  currentPeriodEndAt   DateTime?
  graceEndsAt          DateTime?
  lockedAt             DateTime?
  approvedAt           DateTime?
  approvedByUserId     String?
  supportEndsAt        DateTime?

  tenant                    Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription              Subscription               @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  module                    ModuleCatalog              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  approvedBy                User?                      @relation("SubscriptionItemApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  activationRequestTracking ActivationRequestTracking?

  @@unique([tenantId, subscriptionId, moduleId])
  @@index([tenantId, status])
}

model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String
  actorUserId  String?
  action       String
  entityType   String?
  entityId     String?
  metadataJson Json
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, actorUserId, createdAt(sort: Desc)])
}

model File {
  id              String   @id @default(uuid())
  tenantId        String
  purpose         String
  originalName    String
  contentType     String
  sizeBytes       Int
  storageProvider String
  storageKey      String
  createdAt       DateTime @default(now())

  tenant                        Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usedAsLogoBy                  TenantBranding?                @relation("TenantLogoFile")
  usedAsShopProductImageBy      ShopProduct[]                  @relation("ShopProductImageFile")
  usedAsPrintPressLogoBy        PrintPressSettings?            @relation("PrintPressLogoFile")
  printPressCustomerAttachments PrintPressCustomerAttachment[]
  printPressExpenseAttachments  PrintPressExpenseAttachment[]

  @@index([tenantId, purpose])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tenantId  String?
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([tenantId, expiresAt])
}

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  tenantId         String?
  refreshTokenHash String
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([tenantId, revokedAt])
}

model WaitlistSignup {
  id        String   @id @default(uuid())
  email     String
  name      String?
  company   String?
  moduleId  String?
  locale    String?
  createdAt DateTime @default(now())

  @@unique([email, moduleId])
  @@index([createdAt(sort: Desc)])
}

model PublicContactSubmission {
  id               String   @id @default(uuid())
  fullName         String
  organizationName String?
  email            String
  phoneNumber      String
  serviceType      String
  message          String
  locale           String?
  ip               String?
  userAgent        String?
  createdAt        DateTime @default(now())

  @@index([email])
  @@index([createdAt(sort: Desc)])
}

model TutorialCategory {
  id        String   @id @default(uuid())
  slug      String   @unique
  icon      String
  scope     String
  moduleId  String?
  titleEn   String
  titleFa   String
  titlePs   String
  orderNo   Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  module    ModuleCatalog?   @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  tutorials Tutorial[]
  series    TutorialSeries[]

  @@index([scope, moduleId, isActive, orderNo])
}

model TutorialSeries {
  id            String   @id @default(uuid())
  slug          String   @unique
  scope         String
  moduleId      String?
  categoryId    String?
  titleEn       String
  titleFa       String
  titlePs       String
  descriptionEn String?
  descriptionFa String?
  descriptionPs String?
  thumbnailUrl  String?
  orderNo       Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module    ModuleCatalog?    @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  category  TutorialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tutorials Tutorial[]

  @@index([scope, moduleId, categoryId, isActive, orderNo])
}

model Tutorial {
  id             String   @id @default(uuid())
  slug           String   @unique
  scope          String
  moduleId       String?
  categoryId     String?
  seriesId       String?
  stepNo         Int?
  orderNo        Int      @default(0)
  titleEn        String
  titleFa        String
  titlePs        String
  descriptionEn  String?
  descriptionFa  String?
  descriptionPs  String?
  youtubeUrl     String
  youtubeVideoId String?
  thumbnailUrl   String?
  difficulty     String
  language       String
  durationSec    Int?
  tags           String[] @default([])
  views          Int      @default(0)
  visibility     String
  isFeatured     Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  module   ModuleCatalog?    @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  category TutorialCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  series   TutorialSeries?   @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  relatedFrom TutorialRelation[] @relation("TutorialRelationFrom")
  relatedTo   TutorialRelation[] @relation("TutorialRelationTo")

  @@index([scope, moduleId, categoryId])
  @@index([visibility, isActive])
  @@index([isFeatured, visibility])
  @@index([views])
  @@index([createdAt(sort: Desc)])
  @@index([updatedAt(sort: Desc)])
}

model TutorialRelation {
  id                String   @id @default(uuid())
  tutorialId        String
  relatedTutorialId String
  orderNo           Int      @default(0)
  createdAt         DateTime @default(now())

  tutorial        Tutorial @relation("TutorialRelationFrom", fields: [tutorialId], references: [id], onDelete: Cascade)
  relatedTutorial Tutorial @relation("TutorialRelationTo", fields: [relatedTutorialId], references: [id], onDelete: Cascade)

  @@unique([tutorialId, relatedTutorialId])
  @@index([tutorialId, orderNo])
}

enum PrintPressJobStatus {
  received
  designing
  customer_approval
  printing
  finishing
  packaging
  ready
  delivered
  cancelled
}

enum PrintPressJobPriority {
  low
  normal
  high
  urgent
}

enum PrintPressQuotationStatus {
  draft
  issued
  void
}

enum PrintPressInvoiceStatus {
  draft
  issued
  paid
  void
}

enum PrintPressCustomerType {
  individual
  business
}

enum PrintPressRecurrenceInterval {
  weekly
  monthly
  yearly
}

model PrintPressCustomer {
  id           String                  @id @default(uuid())
  tenantId     String
