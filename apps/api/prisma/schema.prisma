  status    String   @default("active") // active, inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nozzles FuelNozzle[]

  @@index([tenantId])
}

model FuelNozzle {
  id                      String   @id @default(uuid())
  tenantId                String
  pumpId                  String
